#!/bin/sh

# SPDX-FileCopyrightText: 2025 Luca Kredel <luca.kredel@web.de>
#
# SPDX-License-Identifier: GPL-3.0-or-later

usage() {
	cat <<EOF
USAGE:
    $0 [OPTION]... [VAR=VALUE]... [BUILD TYPE]

POSITIONAL ARGUMENTS:
    <BUILD TYPE>
	Set build type, like --build.

VARIABLE ASSIGNMENT
    The value of the CFLAGS, CPPFLAGS, LDFLAGS and CC variables can be
    overriden by supplying them in the form VAR=VALUE.

    These variables are automatically set to their corresponding environment
    variable value.

BUILD OPTIONS:
    --build=<build type>            Set the build type.
    --host=<host type>              Set the host type.
    --srcdir=<path>                 Set srcdir. Defaults to ./src.

INSTALL OPTIONS:
    --prefix=<dir>                  Set prefix path. Defaults to /usr/local/.

OTHER:
    -h, --help                      Show this message and exit.
EOF
exit 0
}

fail() {
	echo "$*"
	exit 1
}

find_compiler() {
	test -z "$cc" && type "$1" >/dev/null 2>&1 && cc=$1;
}

build_type=
host_type=
cc=${CC-}
cflags=${CFLAGS-}
cppflags=${CPPFLAGS-}
ldflags=${LDFLAGS-}
prefix=/usr/local/
srcdir=./src

for arg; do
	case "$arg" in
		--help | -h) usage ;;
		--build=*) build_type=${arg#*=} ;;
		--host=*) host_type=${arg#*=} ;;
		--prefix=*) prefix=${arg#*=} ;;
		CFLAGS=*) cflags=${arg#*=} ;;
		CPPFLAGS=*) cppflags=${arg#*=} ;;
		LDFLAGS=*) ldflags=${arg#*=} ;;
		CC=*) cc=${arg#*=} ;;
		--srcdir=*) srcdir=${arg#*=} ;;
		-*) echo "$0: Unknown option '$arg'" ;;
		*=*) ;;
		*) build_type=$arg ;;
	esac
done

printf "checking for C compiler … "
find_compiler gcc
find_compiler clang

printf "%s\n" "$cc"

printf "checking for build type … "

test -n "$build_type" || \
	build_type=$("$cc" -dumpmachine 2>/dev/null) || build_type=unknown

if [ -z "$host_type" ]; then
	host_type="$build_type"
fi

echo "$build_type"

printf "checking for host type … "

echo "$host_type"

if [ "$host_type" != "$build_type" ]; then
	printf "cross compilation enabled\n"
	build_type="$host_type"

	printf "checking for C cross compiler … "

	type "$host_type-gcc" >/dev/null 2>&1 && cc="$host_type-gcc";

	printf "%s\n" "$cc"
fi

case "$build_type" in
	x86_64*)
		arch=x86_64
		;;
	aarch64*)
		arch=arm64
		;;
	unknown) fail "$0: Could not determine build type. Try $0 --build=…" ;;
	*)
		fail "$0: Unsupported build type \"$build_type\". ";;
esac

printf "writing config.mk … "

cat <<EOF >config.mk
# Do not edit this file by hand—it’ll be overwritten on the next run!
ARCH=$arch
CC=$cc
CFLAGS_CONFIG=$cflags
CPPFLAGS_CONFIG=$cppflags
LDFLAGS_CONFIG=$ldflags
prefix=$prefix
SRCDIR=$srcdir
EOF

printf "done\n"
